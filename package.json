{
  "name": "react-upload-indexeddb",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit && node scripts/verify-client-contract.mjs",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "npm --prefix server test",
    "verify:client": "npm run lint && npm run build && npm run test",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start",
    "verify:server": "npm --prefix server run verify",
    "verify:phase56": "node scripts/verify-phase56-hooks.mjs",
    "verify:encoding": "node scripts/verify-encoding-clean.mjs",
    "metrics:collect": "node scripts/collect-refactor-metrics.mjs",
    "docs:screenshot": "node scripts/capture-readme-screenshots.mjs",
    "verify": "npm run verify:client && npm run verify:server"
  },
  "dependencies": {
    "ahooks": "^3.8.5",
    "antd": "^5.25.4",
    "axios": "^1.9.0",
    "localforage": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "spark-md5": "^3.0.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "eslint": "^9.9.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "jsdom": "^24.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "playwright": "^1.54.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vitest": "^2.1.8"
  }
}
